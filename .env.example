# Database Configuration
POSTGRES_DB=internship_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Keycloak Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_password_here
KC_HTTP_PORT=8080
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8090

# LDAP Configuration
LDAP_ORGANISATION=Spring Framework
LDAP_DOMAIN=springframework.org
LDAP_ADMIN_PASSWORD=your_ldap_password_here
LDAP_BASE_DN=dc=springframework,dc=org

# Application Configuration
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://internship_db:5432/internship_management
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here
SPRING_KAFKA_BOOTSTRAP_SERVERS=broker:29092
AXON_AXONSERVER_SERVERS=axonserver:8124
SPRING_CLOUD_CONSUL_HOST=consul
SPRING_CLOUD_CONSUL_PORT=8500

# Keycloak OAuth2 Configuration
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/finki-services/protocol/openid-connect/certs
KEYCLOAK_ISSUER_URI=http://localhost:8090/realms/finki-services
